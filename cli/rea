#! /usr/bin/env bash
set -o errexit
set -o nounset
set -o pipefail

# Description: ASS-Combiner: combile .cht.ass to mkv
# Usage: rea [input_dir]
# Example: rea 'input'

### Args
INPUT_DIR=${1:-}

# Check arguments
if [ -z "$INPUT_DIR" ]; then
  printf "\033[1mrea\033[0m: ASS-Combiner: combile .cht.ass to mkv\n" >&2
  printf "Usage: \033[1mrea\033[0m [input_dir]\n" >&2
  printf "       \033[1mrea\033[0m 'input'\n" >&2
  exit 1
fi

# Check commands
command -v ffmpeg &>/dev/null || {
  echo "ffmpeg is not installed" >&2
  exit 1
}

# Check directories
[ -d "$INPUT_DIR" ] || {
  echo "Directory $INPUT_DIR not exist" >&2
  exit 1
}

cd "$INPUT_DIR"

### Input file
INPUT_FILE="$(basename "$(pwd)").mkv"
### Input cht ass
INPUT_ASS_TW="$(basename "$(pwd)").cht.ass"
### Input chs ass
INPUT_ASS_CN="$(basename "$(pwd)").chs.ass"

# Check files
[ -f "$INPUT_FILE" ] || {
  echo "File $INPUT_FILE not exist" >&2
  exit 1
}
[ -f "$INPUT_ASS_TW" ] || {
  echo "File $INPUT_ASS_TW not exist" >&2
  exit 1
}
[ -f "$INPUT_ASS_CN" ] || {
  echo "File $INPUT_ASS_CN not exist" >&2
  exit 1
}

### Temp File
TMPFILE="$(mktemp -t "$(basename $0)").mkv"

ffmpeg -y \
  -hide_banner \
  -loglevel error \
  -i "$INPUT_FILE" \
  -i "$INPUT_ASS_TW" \
  -i "$INPUT_ASS_CN" \
  -map 0:v \
  -map 0:a \
  -map 1:s \
  -map 2:s \
  -c copy \
  -metadata:s:s:0 language=chi -metadata:s:s:0 title="繁體中文" \
  -metadata:s:s:1 language=chi -metadata:s:s:1 title="簡體中文" \
  -disposition:s:0 default \
  -disposition:s:1 0 \
  "$TMPFILE"

mv "$TMPFILE" "$INPUT_FILE"
