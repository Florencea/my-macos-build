#! /usr/bin/env bash
set -o errexit
set -o nounset
set -o pipefail

# Description: ASS-Combiner: strip original subtitles and combine .cht.ass as the sole default subtitle track, move up, and clean up directory
# Usage: rea [input_dir]
# Example: rea 'input'

# Colors for output (using standard ANSI colors instead of bold/bright variants for light terminal theme compatibility)
if [[ -t 1 ]]; then
  COLOR_GREEN=$'\033[32m'
  COLOR_RESET=$'\033[0m'
else
  COLOR_GREEN=''
  COLOR_RESET=''
fi

### Args
INPUT_DIR=${1:-}

# Check arguments
if [[ -z "$INPUT_DIR" ]]; then
  printf "${COLOR_GREEN}rea${COLOR_RESET}: ASS-Combiner: strip original subtitles and combine .cht.ass as the sole default subtitle track, move up, and clean up directory\n" >&2
  printf "Usage: ${COLOR_GREEN}rea${COLOR_RESET} [input_dir]\n" >&2
  printf "       ${COLOR_GREEN}rea${COLOR_RESET} 'input'\n" >&2
  exit 1
fi

# Check commands
command -v ffmpeg &>/dev/null || {
  echo "ffmpeg is not installed" >&2
  exit 1
}

# Check directories
[[ -d "$INPUT_DIR" ]] || {
  echo "Directory $INPUT_DIR not exist" >&2
  exit 1
}

# Resolve paths
INPUT_BASE="$(basename "$INPUT_DIR")"
ABS_INPUT_DIR="$(cd "$INPUT_DIR" && pwd)"
PARENT_DIR="$(dirname "$ABS_INPUT_DIR")"

# Safety guard: prevent deleting root or empty paths
if [[ "$ABS_INPUT_DIR" == "/" || -z "$ABS_INPUT_DIR" ]]; then
  echo "Safety guard: ABS_INPUT_DIR cannot be root or empty" >&2
  exit 1
fi

### Find input files (.mkv and .cht.ass) in input directory
shopt -s nullglob
MKV_FILES=( "${ABS_INPUT_DIR}"/*.mkv )
ASS_FILES=( "${ABS_INPUT_DIR}"/*.cht.ass )
shopt -u nullglob

if [[ ${#MKV_FILES[@]} -eq 0 ]]; then
  echo "No .mkv file found in $INPUT_DIR" >&2
  exit 1
fi
if [[ ${#ASS_FILES[@]} -eq 0 ]]; then
  echo "No .cht.ass file found in $INPUT_DIR" >&2
  exit 1
fi

INPUT_FILE="${MKV_FILES[0]}"
INPUT_ASS_TW="${ASS_FILES[0]}"

### Temp Files & Output File
TMPFILE="${PARENT_DIR}/.tmp_$(basename "$0")_$$.mkv"
OUTPUT_FILE="${PARENT_DIR}/${INPUT_BASE}.mkv"

# Set trap for cleanup of temp file
trap 'rm -f "$TMPFILE"' EXIT

# Mux .cht.ass into mkv as the sole default subtitle track (stripping original subtitles)
ffmpeg -y \
  -hide_banner \
  -loglevel error \
  -i "$INPUT_FILE" \
  -i "$INPUT_ASS_TW" \
  -map 0:v \
  -map 0:a \
  -map 1:s \
  -c copy \
  -disposition:s:0 default \
  -metadata:s:s:0 language=chi \
  -metadata:s:s:0 title="繁體中文" \
  "$TMPFILE"


mv "$TMPFILE" "$OUTPUT_FILE"

# Clean up input directory entirely
rm -rf "$ABS_INPUT_DIR"



