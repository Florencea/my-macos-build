#! /usr/bin/env bash
set -o errexit
set -o nounset
set -o pipefail

# Description: Gif Maker (Supports --fps [value] parameter, 480p, q100, local files and YouTube videos)
# Usage: mkgif [--fps 12] [input_file_or_url] [from(hh:mm:ss or sec)] [during(sec)]
# Example: mkgif 'input.mp4' 01:02:08 11.0
#          mkgif JoSY6AWKqHs 00:01:59 2 --fps 24

# Colors for output (using standard ANSI colors instead of bold/bright variants for light terminal theme compatibility)
if [[ -t 1 ]]; then
  COLOR_GREEN=$'\033[32m'
  COLOR_RESET=$'\033[0m'
else
  COLOR_GREEN=''
  COLOR_RESET=''
fi

### Args
FPS=12
TEMP_ARGS=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --fps)
      if [[ $# -lt 2 ]]; then
        echo "Error: --fps requires a value" >&2
        exit 1
      fi
      FPS="$2"
      shift 2
      ;;
    *)
      TEMP_ARGS+=("$1")
      shift 1
      ;;
  esac
done

# Restore positional parameters
set -- "${TEMP_ARGS[@]}"

INPUT_FILE=${1:-}
START=${2:-}
DURATION=${3:-}

# Check arguments
if [[ -z "$DURATION" ]]; then
  printf "${COLOR_GREEN}mkgif${COLOR_RESET}: Gif Maker (Supports --fps [value] parameter, 480p, q100, local files and YouTube videos)\n" >&2
  printf "Usage: ${COLOR_GREEN}mkgif${COLOR_RESET} [--fps 12] [input_file_or_url] [from(hh:mm:ss or sec)] [during(sec)]\n" >&2
  printf "       ${COLOR_GREEN}mkgif${COLOR_RESET} 'input.mp4' 01:02:08 11.0\n" >&2
  printf "       ${COLOR_GREEN}mkgif${COLOR_RESET} JoSY6AWKqHs 00:01:59 2 --fps 24\n" >&2
  exit 1
fi

# Check commands
command -v ffmpeg &>/dev/null || {
  echo "ffmpeg is not installed" >&2
  exit 1
}
command -v gifski &>/dev/null || {
  echo "gifski is not installed" >&2
  exit 1
}

IS_YT=false
INPUT_SOURCE="$INPUT_FILE"

# Check if input exists as a file; if not, treat as YouTube source
if [[ ! -f "$INPUT_FILE" ]]; then
  command -v yt-dlp &>/dev/null || {
    echo "File $INPUT_FILE not exist and yt-dlp is not installed" >&2
    exit 1
  }
  IS_YT=true
fi

if [ "$IS_YT" = true ]; then
  STREAM_URL=$(yt-dlp -g -f "bestvideo[height<=480]" -S "vcodec:h264" "$INPUT_FILE" 2>/dev/null || true)
  if [[ -z "$STREAM_URL" ]]; then
    echo "Failed to get stream URL from yt-dlp for input: $INPUT_FILE" >&2
    exit 1
  fi
  INPUT_SOURCE="$STREAM_URL"
fi

### quality
QUALITY=85
### width
WIDTH=480
### Output file
OUTPUT_FILE="$(date +"%Y%m%d%H%M%S")_fps${FPS}.gif"

ffmpeg -y -hide_banner \
  -loglevel error \
  -ss "$START" \
  -i "$INPUT_SOURCE" \
  -t "$DURATION" \
  -vf "fps=$FPS,scale=$WIDTH:-1:flags=lanczos,format=yuv420p" \
  -f yuv4mpegpipe - |
  gifski -q \
    -Q "$QUALITY" \
    -o "$OUTPUT_FILE" -

printf "%s " "$OUTPUT_FILE"
ls -lh "$OUTPUT_FILE" | awk -F " " {'print $5'}
