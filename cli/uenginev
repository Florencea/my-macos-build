#! /usr/bin/env bash
set -o errexit
set -o pipefail

### Check cmd exist
chkcmd "git"
chkcmd "node"
chkcmd "pnpm"
chkcmd "jq"

### Print current node/pnpm version
CURRENT_LOCAL_VERSION="$(node -v)"
CURRENT_PNPM_VERSION="$(pnpm -v)"
printf "\nnode: \033[1;32m$CURRENT_LOCAL_VERSION\033[0m, pnpm: \033[1;32m$CURRENT_PNPM_VERSION\033[0m\n\n"

### Get exact versions (remove 'v' prefix from node version)
NODE_VERSION="$(echo "$CURRENT_LOCAL_VERSION" | sed 's/^v//')"
PNPM_VERSION="$CURRENT_PNPM_VERSION"

### Sync git projects
cd "$(dirname $0)"
cd "../../"
for PROJECT in $(ls .); do
  cd "$PROJECT"
  if [ -d .git ]; then
    ### If exist .node-version change, skip it
    if [[ ! -f .node-version ]]; then
      if [[ -f package.json ]]; then
        OLD_NODE_VERSION="$(jq -r '.engines.node // ""' package.json)"

        # Use jq update package.json
        TMP_PKG=$(mktemp)
        jq ".engines.node = \"$NODE_VERSION\" | .engines.pnpm = \"$PNPM_VERSION\"" package.json >"$TMP_PKG" && mv "$TMP_PKG" package.json

        ### If files changed, add to git
        if [ "$(git status --short)" != "" ]; then
          git add package.json
          git commit -q -m "chore(node): update exact engines (node $NODE_VERSION, pnpm $PNPM_VERSION)"
          git push -q &>/dev/null &
          printf "Updated \033[1;31m%s\033[0m -> \033[1;36m%s\033[0m (pnpm \033[1;36m%s\033[0m) \033[1m%s\033[0m\n" "$OLD_NODE_VERSION" "$NODE_VERSION" "$PNPM_VERSION" "$PROJECT"
        else
          printf "No changes (node \033[1;32m%s\033[0m, pnpm \033[1;36m%s\033[0m) \033[1m%s\033[0m\n" "$OLD_NODE_VERSION" "$PNPM_VERSION" "$PROJECT"
        fi
      fi
    else
      printf "exist .node-version \033[1;32m%s\033[0m \033[1m%s\033[0m skip.\n" "$PROJECT"
    fi
  fi
  cd "../"
done

wait
