#! /usr/bin/env bash
set -o errexit
set -o nounset
set -o pipefail

# Description: Clip Maker
# Usage: mkclp [input_file] [from(hh:mm:ss or sec)] [during(sec)]
# Example: mkclp 'input.mp4' 01:02:08 11.0


### Args
INPUT_FILE=${1:-}
START=${2:-}
DURATION=${3:-}

# Check arguments
if [ -z "$DURATION" ]; then
  printf "\033[1mmkclp\033[0m: Clip Maker\n" >&2
  printf "Usage: \033[1mmkclp\033[0m [input_file] [from(hh:mm:ss or sec)] [during(sec)]\n" >&2
  printf "       \033[1mmkclp\033[0m 'input.mp4' 01:02:08 11.0\n" >&2
  exit 1
fi

# Check commands
command -v ffmpeg &> /dev/null || { echo "ffmpeg is not installed" >&2; exit 1; }

# Check files
[ -f "$INPUT_FILE" ] || { echo "File $INPUT_FILE not exist" >&2; exit 1; }

### Output file
OUTPUT_FILE="$(date +"%Y%m%d%H%M%S")_clip.mp4"

ffmpeg -y -hide_banner \
  -loglevel error \
  -ss "$START" \
  -i "$INPUT_FILE" \
  -t "$DURATION" \
  -map 0:v:0 \
  -map 0:a:0 \
  -c:v copy \
  -c:a aac \
  -map_chapters -1 \
  -movflags +faststart \
  "$OUTPUT_FILE"

printf "%s " "$OUTPUT_FILE"
ls -lh "$OUTPUT_FILE" | awk -F " " {'print $5'}
