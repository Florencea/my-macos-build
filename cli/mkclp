#! /usr/bin/env bash
set -o errexit
set -o nounset
set -o pipefail

# Description: Clip Maker (Supports local files and YouTube videos)
# Usage: mkclp [input_file_or_url] [from(hh:mm:ss or sec)] [during(sec)]
# Example: mkclp 'input.mp4' 01:02:08 11.0
#          mkclp JoSY6AWKqHs 00:01:59 2

### Args
INPUT_FILE=${1:-}
START=${2:-}
DURATION=${3:-}

# Check arguments
if [[ -z "$DURATION" ]]; then
  printf "\033[1mmkclp\033[0m: Clip Maker (Supports local files and YouTube videos)\n" >&2
  printf "Usage: \033[1mmkclp\033[0m [input_file_or_url] [from(hh:mm:ss or sec)] [during(sec)]\n" >&2
  printf "       \033[1mmkclp\033[0m 'input.mp4' 01:02:08 11.0\n" >&2
  printf "       \033[1mmkclp\033[0m JoSY6AWKqHs 00:01:59 2\n" >&2
  exit 1
fi

# Check commands
command -v ffmpeg &>/dev/null || {
  echo "ffmpeg is not installed" >&2
  exit 1
}
command -v ffprobe &>/dev/null || {
  echo "ffprobe is not installed" >&2
  exit 1
}

IS_YT=false
INPUT_SOURCE="$INPUT_FILE"

# Check if input exists as a file; if not, treat as YouTube source
if [[ ! -f "$INPUT_FILE" ]]; then
  command -v yt-dlp &>/dev/null || {
    echo "File $INPUT_FILE not exist and yt-dlp is not installed" >&2
    exit 1
  }
  IS_YT=true
fi

VC_ARGS=(-c:v copy)

if [ "$IS_YT" = true ]; then
  STREAM_URL=$(yt-dlp -g -S "vcodec:h264,acodec:m4a" "$INPUT_FILE" 2>/dev/null || true)
  if [[ -z "$STREAM_URL" ]]; then
    echo "Failed to get stream URL from yt-dlp for input: $INPUT_FILE" >&2
    exit 1
  fi
  INPUT_SOURCE="$STREAM_URL"
  # Use optimized HEVC settings for compatibility with Apple devices and Line
  VC_ARGS=(-c:v hevc_videotoolbox -q:v 45 -profile:v main -pix_fmt yuv420p -tag:v hvc1)
else
  # Detect container format and video codec
  FORMAT=$(ffprobe -v error -show_entries format=format_name -of default=noprint_wrappers=1:nokey=1 "$INPUT_SOURCE" || true)
  VIDEO_CODEC=$(ffprobe -v error -select_streams v:0 -show_entries stream=codec_name -of default=noprint_wrappers=1:nokey=1 "$INPUT_SOURCE" || true)

  # If container format is not mp4, or video codec is not h264/hevc, re-encode with hevc_videotoolbox
  if [[ ! "$FORMAT" =~ "mp4" ]] || [[ "$VIDEO_CODEC" != "h264" && "$VIDEO_CODEC" != "hevc" ]]; then
    VC_ARGS=(-c:v hevc_videotoolbox -q:v 45 -profile:v main -pix_fmt yuv420p -tag:v hvc1)
  fi
fi

### Output file
OUTPUT_FILE="$(date +"%Y%m%d%H%M%S")_clip.mp4"

ffmpeg -y -hide_banner \
  -loglevel error \
  -ss "$START" \
  -i "$INPUT_SOURCE" \
  -t "$DURATION" \
  -map 0:v:0 \
  -map 0:a:0? \
  "${VC_ARGS[@]}" \
  -c:a aac \
  -map_chapters -1 \
  -movflags +faststart \
  "$OUTPUT_FILE"

printf "%s " "$OUTPUT_FILE"
ls -lh "$OUTPUT_FILE" | awk -F " " {'print $5'}

