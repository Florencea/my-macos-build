#! /usr/bin/env bash
set -o errexit
set -o nounset
set -o pipefail

# Description: Backup and sync browser extension configuration files
# Usage: ebk
# Example: ebk

command -v git &>/dev/null || {
  echo "git is not installed" >&2
  exit 1
}
command -v jq &>/dev/null || {
  echo "jq is not installed" >&2
  exit 1
}

### Copy config
### Usage: copy <FILE_PATH> <FILE_NAME>
function copy() {
  CONFIG_HOME="$(dirname "$(dirname $0)")/configs"
  FILE_PATH=${1:-}
  FILE_NAME=${2:-}
  if [[ -f "$FILE_PATH" ]]; then
    cp "$FILE_PATH" "$CONFIG_HOME/$FILE_NAME"
    cd "$CONFIG_HOME" || exit
    git add "$FILE_NAME"
    if [[ -n "$(git status --porcelain)" ]]; then
      echo ""
      printf "Copy Configuration: %s\n" "$FILE_PATH"
      printf "     --> %s\n\n" "$FILE_NAME"
      printf "Backup..."
      git commit -q -m "feat: Update config $FILE_NAME by ebk"
      git push -q
      echo "done."
      echo ""
    fi
  fi
}

### Backup config
### Usage: backup <FILE_PATTERN> <FILE_NAME>
function backup() {
  CONFIG_HOME="$(dirname "$(dirname $0)")/configs"
  FILE_PATTERN=${1:-}
  FILE_NAME=${2:-}
  FILE_BACKUP=$(find "$HOME/Downloads" -maxdepth 1 -name "$FILE_PATTERN" | head -n1)
  if [[ -f "$FILE_BACKUP" ]]; then
    mv "$FILE_BACKUP" "$CONFIG_HOME/$FILE_NAME"
    cd "$CONFIG_HOME" || exit
    git add "$FILE_NAME"
    echo ""
    printf "Find Configuration: %s\n" "$FILE_BACKUP"
    printf "     --> %s\n\n" "$FILE_NAME"
    printf "Backup..."
    git commit -q -m "feat: Update $FILE_NAME by ebk"
    git push -q
    echo "done."
    echo ""
  fi
}

### Backup and format json
### Usage: backupjson <FILE_PATTERN> <FILE_NAME>
function backupjson() {
  CONFIG_HOME="$(dirname "$(dirname $0)")/configs"
  FILE_PATTERN=${1:-}
  FILE_NAME=${2:-}
  FILE_BACKUP=$(find "$HOME/Downloads" -maxdepth 1 -name "$FILE_PATTERN" | head -n1)
  if [[ -f "$FILE_BACKUP" ]]; then
    mv "$FILE_BACKUP" "$CONFIG_HOME/temp.json"
    cd "$CONFIG_HOME" || exit
    jq . temp.json >"$FILE_NAME"
    rm temp.json
    git add "$FILE_NAME"
    echo ""
    printf "Find Configuration: %s\n" "$FILE_BACKUP"
    printf "     --> %s\n\n" "$FILE_NAME"
    printf "Backup..."
    git commit -q -m "feat: Update $FILE_NAME by ebk"
    git push -q
    echo "done."
    echo ""
  fi
}

### Backup Antigravity IDE settings and extensions
### Usage: backup_antigravity_ide
function backup_antigravity_ide() {
  CONFIG_HOME="$(cd "$(dirname "$(dirname "$0")")/configs" && pwd)"
  IDE_CONFIG_DIR="$CONFIG_HOME/antigravity-ide"
  mkdir -p "$IDE_CONFIG_DIR"

  SRC_SETTINGS="${HOME:-}/Library/Application Support/Antigravity IDE/User/settings.json"
  SRC_EXTENSIONS="${HOME:-}/.antigravity-ide/extensions/extensions.json"

  DEST_SETTINGS="$IDE_CONFIG_DIR/settings.json"
  DEST_EXTENSIONS="$IDE_CONFIG_DIR/extensions.json"

  CHANGED=0

  # 1. Backup settings.json (Keep raw format for possible comments)
  if [[ -f "$SRC_SETTINGS" ]]; then
    if [[ ! -f "$DEST_SETTINGS" ]] || ! cmp -s "$SRC_SETTINGS" "$DEST_SETTINGS"; then
      cp "$SRC_SETTINGS" "$DEST_SETTINGS"
      cd "$CONFIG_HOME" || exit
      git add "antigravity-ide/settings.json"
      echo ""
      printf "Copy Antigravity IDE Settings: %s\n" "$SRC_SETTINGS"
      printf "     --> %s\n\n" "antigravity-ide/settings.json"
      CHANGED=1
    fi
  fi

  # 2. Backup extensions.json (Format with jq for better diff)
  if [[ -f "$SRC_EXTENSIONS" ]]; then
    TEMP_EXTENSIONS="$IDE_CONFIG_DIR/temp_extensions.json"
    jq . "$SRC_EXTENSIONS" > "$TEMP_EXTENSIONS"

    if [[ ! -f "$DEST_EXTENSIONS" ]] || ! cmp -s "$TEMP_EXTENSIONS" "$DEST_EXTENSIONS"; then
      mv "$TEMP_EXTENSIONS" "$DEST_EXTENSIONS"
      cd "$CONFIG_HOME" || exit
      git add "antigravity-ide/extensions.json"
      echo ""
      printf "Copy Antigravity IDE Extensions: %s\n" "$SRC_EXTENSIONS"
      printf "     --> %s\n\n" "antigravity-ide/extensions.json"
      CHANGED=1
    else
      rm -f "$TEMP_EXTENSIONS"
    fi
  fi

  if [[ "$CHANGED" -eq 1 ]]; then
    cd "$CONFIG_HOME" || exit
    printf "Backup Antigravity IDE configurations..."
    git commit -q -m "feat: Update Antigravity IDE configs by ebk"
    git push -q
    echo "done."
    echo ""
  fi
}

backupjson "my-ubol-settings.json" "ubol-config.json"
backupjson "immersive-translate-config-with-terms-*.json" "immersive-translate-config.json"
backupjson "tampermonkey-backup-*.txt" "tampermonkey.json"
backupjson "stylus-*.json" "stylus.json"
backup_antigravity_ide


