#! /usr/bin/env bash
set -o errexit
set -o nounset
set -o pipefail

# Description: Gif Maker (24fps, 480p, q100, supports local files and YouTube videos)
# Usage: mkgifv [input_file_or_url] [from(hh:mm:ss or sec)] [during(sec)]
# Example: mkgifv 'input.mp4' 01:02:08 11.0
#          mkgifv JoSY6AWKqHs 00:01:59 2

### Args
INPUT_FILE=${1:-}
START=${2:-}
DURATION=${3:-}

# Check arguments
if [[ -z "$DURATION" ]]; then
  printf "\033[1mmkgifv\033[0m: Gif Maker (24fps, 480p, q100, supports local files and YouTube videos)\n" >&2
  printf "Usage: \033[1mmkgifv\033[0m [input_file_or_url] [from(hh:mm:ss or sec)] [during(sec)]\n" >&2
  printf "       \033[1mmkgifv\033[0m 'input.mp4' 01:02:08 11.0\n" >&2
  printf "       \033[1mmkgifv\033[0m JoSY6AWKqHs 00:01:59 2\n" >&2
  exit 1
fi

# Check commands
command -v ffmpeg &>/dev/null || {
  echo "ffmpeg is not installed" >&2
  exit 1
}
command -v gifski &>/dev/null || {
  echo "gifski is not installed" >&2
  exit 1
}

IS_YT=false
INPUT_SOURCE="$INPUT_FILE"

# Check if input exists as a file; if not, treat as YouTube source
if [[ ! -f "$INPUT_FILE" ]]; then
  command -v yt-dlp &>/dev/null || {
    echo "File $INPUT_FILE not exist and yt-dlp is not installed" >&2
    exit 1
  }
  IS_YT=true
fi

if [ "$IS_YT" = true ]; then
  STREAM_URL=$(yt-dlp -g -f "bestvideo[height<=480]" -S "vcodec:h264" "$INPUT_FILE" 2>/dev/null || true)
  if [[ -z "$STREAM_URL" ]]; then
    echo "Failed to get stream URL from yt-dlp for input: $INPUT_FILE" >&2
    exit 1
  fi
  INPUT_SOURCE="$STREAM_URL"
fi

### quality
QUALITY=85
### fps
FPS=24
### width
WIDTH=480
### Output file
OUTPUT_FILE="$(date +"%Y%m%d%H%M%S")_v.gif"

ffmpeg -y -hide_banner \
  -loglevel error \
  -ss "$START" \
  -i "$INPUT_SOURCE" \
  -t "$DURATION" \
  -vf "fps=$FPS,scale=$WIDTH:-1:flags=lanczos,format=yuv420p" \
  -f yuv4mpegpipe - |
  gifski -q \
    -Q "$QUALITY" \
    -o "$OUTPUT_FILE" -

printf "%s " "$OUTPUT_FILE"
ls -lh "$OUTPUT_FILE" | awk -F " " {'print $5'}
