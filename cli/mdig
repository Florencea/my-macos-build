#! /usr/bin/env bash
set -o errexit
set -o nounset
set -o pipefail

# Description: Multi-dig: Check A records on different DNS server at once.
# Usage: mdig [domain]
# Example: mdig 'is1-ssl.mzstatic.com'

### Args
DOMAIN=${1:-}

# Check arguments
if [ -z "$DOMAIN" ]; then
  printf "\033[1mmdig\033[0m: Multi-dig: Check A records on different DNS server at once.\n" >&2
  printf "Usage: \033[1mmdig\033[0m [domain]\n" >&2
  printf "       \033[1mmdig\033[0m 'is1-ssl.mzstatic.com'\n" >&2
  exit 1
fi

# Check commands
command -v dig &>/dev/null || {
  echo "dig is not installed" >&2
  exit 1
}

DNS_SERVERS=(
  "Google|8.8.8.8"
  "Cloudflare|1.1.1.1"
  "Hinet|168.95.192.1"
  "Hinet|168.95.1.1"
  "System|"
)

# Create a temporary directory for storing parallel query results
TEMP_DIR=$(mktemp -d)
cleanup() {
  rm -rf "$TEMP_DIR"
}
trap cleanup EXIT

# Run queries in parallel
for i in "${!DNS_SERVERS[@]}"; do
  (
    IFS='|' read -ra ADDR <<<"${DNS_SERVERS[$i]}"
    SERVER_NAME=${ADDR[0]}
    SERVER_IP=${ADDR[1]:-}

    if [ "$SERVER_NAME" = "System" ]; then
      printf "\033[1mSystem\033[0m\n"
      OUTPUT=$(dig "$DOMAIN" +noclass +nottl +noall +answer +stats +time=2 +tries=1 2>/dev/null || true)
    else
      printf "\033[1m%s\033[0m %s\n" "$SERVER_NAME" "$SERVER_IP"
      OUTPUT=$(dig "@$SERVER_IP" "$DOMAIN" +noclass +nottl +noall +answer +stats +time=2 +tries=1 2>/dev/null || true)
    fi

    if [ -z "$OUTPUT" ]; then
      echo "[Timeout/Error]"
    else
      echo "$OUTPUT" | awk '$2 == "A" {print $3} /Query time/ {print "time: "$4, "ms"}'
    fi
    echo ""
  ) > "$TEMP_DIR/res_$i" &
done

# Wait for all background queries to complete
wait

# Output the results in the original order
for i in "${!DNS_SERVERS[@]}"; do
  cat "$TEMP_DIR/res_$i"
done
