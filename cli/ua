#! /usr/bin/env bash
set -o errexit
set -o nounset
set -o pipefail

# Description: Upgrade Homebrew formulas, update Node.js (via fnm), and sync all git repositories in workspace
# Usage: ua
# Example: ua

# Check commands
command -v brew &>/dev/null || {
  echo "brew is not installed" >&2
  exit 1
}
command -v fnm &>/dev/null || {
  echo "fnm is not installed" >&2
  exit 1
}
command -v git &>/dev/null || {
  echo "git is not installed" >&2
  exit 1
}
command -v node &>/dev/null || {
  echo "node is not installed" >&2
  exit 1
}

# Colors for output (using standard ANSI colors instead of bold/bright variants for light terminal theme compatibility)
if [[ -t 1 ]]; then
  COLOR_GREEN=$'\033[32m'
  COLOR_CYAN=$'\033[36m'
  COLOR_RED=$'\033[31m'
  COLOR_BOLD=$'\033[1;34m' # Use Bold Blue to prevent text from turning white in light terminal themes
  COLOR_RESET=$'\033[0m'
else
  COLOR_GREEN=''
  COLOR_CYAN=''
  COLOR_RED=''
  COLOR_BOLD=''
  COLOR_RESET=''
fi

### Upgrade homebrew apps/clis
cd "$HOME"
# Disable greedy upgrades to prevent updating auto-updating apps (e.g. microsoft-edge)
HOMEBREW_NO_ENV_HINTS=1 HOMEBREW_NO_ASK=1 HOMEBREW_NO_UPGRADE_AUTO_UPDATES_CASKS=1 brew upgrade
HOMEBREW_NO_ENV_HINTS=1 brew cleanup

### Update Node.js
### Change this line for preferred version (start by 'v', ex: v20, v24)
PREFERRED_NODEJS_VERSION="v24"
###
if PREFERRED_NODEJS_REMOTE_VERSION="$(fnm list-remote --filter "$PREFERRED_NODEJS_VERSION" --latest 2>/dev/null)" && [[ -n "$PREFERRED_NODEJS_REMOTE_VERSION" ]]; then
  # Strip LTS nickname (e.g. "v24.16.0 (Krypton)" -> "v24.16.0")
  PREFERRED_NODEJS_REMOTE_VERSION="${PREFERRED_NODEJS_REMOTE_VERSION%% *}"
  CURRENT_LOCAL_VERSION="$(node -v)"
  if [[ "$PREFERRED_NODEJS_REMOTE_VERSION" != "$CURRENT_LOCAL_VERSION" ]]; then
    printf "Preferred Node.js version: ${COLOR_GREEN}%s${COLOR_RESET}, remote: ${COLOR_CYAN}%s${COLOR_RESET}, local: ${COLOR_RED}%s${COLOR_RESET}, install from remote\n" \
      "$PREFERRED_NODEJS_VERSION" "$PREFERRED_NODEJS_REMOTE_VERSION" "$CURRENT_LOCAL_VERSION"
    fnm install "$PREFERRED_NODEJS_REMOTE_VERSION" &>/dev/null
    fnm default "$PREFERRED_NODEJS_REMOTE_VERSION" &>/dev/null
    fnm uninstall "$CURRENT_LOCAL_VERSION" &>/dev/null
    NODE_UPDATED="true"
  fi
else
  printf "Warning: Failed to fetch remote Node.js version for $PREFERRED_NODEJS_VERSION. Skipping Node.js update.\n" >&2
fi

### Print current node/npm version
if [[ "${NODE_UPDATED:-false}" == "true" ]]; then
  CURRENT_LOCAL_VERSION="$(fnm exec --using="$PREFERRED_NODEJS_REMOTE_VERSION" node -v)"
  CURRENT_NPM_VERSION="$(fnm exec --using="$PREFERRED_NODEJS_REMOTE_VERSION" npm -v)"
else
  CURRENT_LOCAL_VERSION="$(node -v)"
  CURRENT_NPM_VERSION="$(npm -v)"
fi
printf "\nnode: ${COLOR_GREEN}%s${COLOR_RESET}, npm: ${COLOR_GREEN}%s${COLOR_RESET}\n\n" "$CURRENT_LOCAL_VERSION" "$CURRENT_NPM_VERSION"

### Sync git projects
SCRIPT_PATH="$(dirname "$(readlink -f "$0" 2>/dev/null || realpath "$0")")"
PROJECTS_DIR="$(cd "$SCRIPT_PATH/../.." && pwd)"

if cd "$PROJECTS_DIR"; then
  for PROJECT in */; do
    [[ -d "$PROJECT" ]] || continue
    PROJECT="${PROJECT%/}"
    if [[ -d "$PROJECT/.git" ]]; then
      git -C "$PROJECT" pull --all --quiet && printf "Sync ${COLOR_BOLD}%s${COLOR_RESET} ok\n" "$PROJECT" &
    fi
  done
  wait
fi
