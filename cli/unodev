#! /usr/bin/env bash
set -o errexit
set -o nounset
set -o pipefail

# Description: Sync and update Node.js version in package.json engines.node for all local workspace projects
# Usage: unodev
# Example: unodev

# Check commands
command -v git &>/dev/null || {
  echo "git is not installed" >&2
  exit 1
}
command -v node &>/dev/null || {
  echo "node is not installed" >&2
  exit 1
}
command -v npm &>/dev/null || {
  echo "npm is not installed" >&2
  exit 1
}

# Colors for output (using standard ANSI colors instead of bold/bright variants for light terminal theme compatibility)
if [[ -t 1 ]]; then
  COLOR_GREEN=$'\033[32m'
  COLOR_CYAN=$'\033[36m'
  COLOR_RED=$'\033[31m'
  COLOR_BOLD=$'\033[1m'
  COLOR_RESET=$'\033[0m'
else
  COLOR_GREEN=''
  COLOR_CYAN=''
  COLOR_RED=''
  COLOR_BOLD=''
  COLOR_RESET=''
fi

# Print current node/npm version
CURRENT_LOCAL_VERSION="$(node -v)"
CURRENT_NPM_VERSION="$(npm -v)"
printf "\nnode: ${COLOR_GREEN}%s${COLOR_RESET}, npm: ${COLOR_GREEN}%s${COLOR_RESET}\n\n" "$CURRENT_LOCAL_VERSION" "$CURRENT_NPM_VERSION"

# Extract raw active node version once
NODE_VERSION="${CURRENT_LOCAL_VERSION#v}"

# Define workspace directories referencing cli/ua
SCRIPT_PATH="$(dirname "$(readlink -f "$0" 2>/dev/null || realpath "$0")")"
PROJECTS_DIR="$(cd "$SCRIPT_PATH/../.." && pwd)"

if cd "$PROJECTS_DIR"; then
  for PROJECT in */; do
    [[ -d "$PROJECT" ]] || continue
    PROJECT="${PROJECT%/}"
    
    # Skip hidden folders
    [[ "$PROJECT" == .* ]] && continue

    if [[ -d "$PROJECT/.git" ]]; then
      if [[ ! -f "$PROJECT/.node-version" ]]; then
        if [[ -f "$PROJECT/package.json" ]]; then
          # Fast read using node -e with absolute path to avoid slow npm pkg get
          OLD_NODE_VERSION=$(node -e "try { console.log(require('${PROJECTS_DIR}/${PROJECT}/package.json').engines.node || '') } catch(e) {}")
          
          if [[ "$OLD_NODE_VERSION" != "$NODE_VERSION" ]]; then
            (
              cd "$PROJECT"
              npm pkg set engines.node="$NODE_VERSION"
              
              if [[ -n "$(git status --short)" ]]; then
                git add package.json
                if git commit -q -m "chore(node): Update engines.node $OLD_NODE_VERSION -> $NODE_VERSION"; then
                  if git push -q &>/dev/null; then
                    printf "engines.node ${COLOR_BOLD}%s${COLOR_RESET}: ${COLOR_RED}%s${COLOR_RESET} -> ${COLOR_CYAN}%s${COLOR_RESET} ok\n" "$PROJECT" "$OLD_NODE_VERSION" "$NODE_VERSION"
                  else
                    printf "engines.node ${COLOR_BOLD}%s${COLOR_RESET}: ${COLOR_RED}failed to push${COLOR_RESET}\n" "$PROJECT" >&2
                  fi
                fi
              fi
            ) &
          else
            printf "engines.node ${COLOR_BOLD}%s${COLOR_RESET}: ${COLOR_GREEN}%s${COLOR_RESET} ok\n" "$PROJECT" "$OLD_NODE_VERSION"
          fi
        fi
      else
        printf "engines.node ${COLOR_BOLD}%s${COLOR_RESET}: skip (.node-version exists)\n" "$PROJECT"
      fi
    fi
  done
  wait
fi
